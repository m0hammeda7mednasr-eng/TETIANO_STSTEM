# Shopify App Credentials (get these from your Shopify Partner Dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Supabase Credentials
SUPABASE_URL=your_supabase_url
# Required for backend reads/writes (recommended)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional fallback (not recommended for backend)
SUPABASE_KEY=your_supabase_anon_key

# JWT Secret for signing user tokens
JWT_SECRET=your_super_secret_and_long_jwt_key

# Application URLs
# The public URL of your frontend (e.g., http://localhost:3000 for local dev)
FRONTEND_URL=http://localhost:3000

# The public URL of your backend. IMPORTANT for Shopify OAuth callback.
# Use your ngrok tunnel URL here for local development (e.g., https://your-tunnel.ngrok-free.dev)
BACKEND_URL=http://localhost:5000

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development
